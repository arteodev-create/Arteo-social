# Arteo Platform - Environmental Blueprint
# Standardized for Version 14.1 (Platinum Architecture)

# Infrastructure
NODE_ENV=development
PORT=5000
NODE_NAME=arteo-primary-server
NODE_REGION=global

# Database (Supabase)
SUPABASE_DB_URL=
DATABASE_URL=${SUPABASE_DB_URL}
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_AUTH_ENABLED=true

# Authentication & Security Protocols
# Generate strong secrets (min 32 chars): openssl rand -base64 32
JWT_ACCESS_SECRET=your_platinum_access_secret_here
JWT_REFRESH_SECRET=your_platinum_refresh_secret_here

# Real-time Signal Hub (Socket.IO)
# Use the same FRONTEND_URL as authorized in CORS
FRONTEND_URL=https://arteosocial.com

# SMTP Transactional Infrastructure (Resend/SendGrid/SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_smtp_password_here
EMAIL_FROM="Arteo Social <noreply@yourdomain.com>"
SMTP_SECURE=true

# Media & Storage Cluster (AWS S3)
AWS_S3_BUCKET=your_s3_bucket_name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Optional: Cache Orchestration (Redis)
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
