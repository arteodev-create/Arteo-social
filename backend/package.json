{
  "name": "@arteo/backend",
  "version": "2.1.0",
  "description": "Arteo Platform High-Fidelity API Engine (Majestic Architecture)",
  "main": "Server.js",
  "scripts": {
    "start": "node Server.js",
    "dev": "nodemon Server.js",
    "worker:email": "node src/workers/Email.Worker.js",
    "worker:notification": "node src/workers/Notification.Worker.js",
    "worker:feed": "node src/workers/FeedFanout.Worker.js",
    "test": "jest",
    "check:syntax": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-ChildItem -Path src -Recurse -Filter *.js | ForEach-Object { node --check $_.FullName }\"",
    "check:prisma": "prisma validate",
    "check": "npm run check:syntax && npm run check:prisma"
  },
  "dependencies": {
    "@arteoapp/recode-plugin": "file:./libs/recode-plugin",
