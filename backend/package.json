    "@supabase/supabase-js": "^2.105.3",
    "@upstash/redis": "^1.36.1",
    "axios": "^1.13.2",
    "bad-words": "^3.0.4",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dompurify": "^3.3.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "helmet": "^7.2.0",
